# Copy to .env and fill in. The UAT CLI reads this automatically.

# Required for Tier-B (real-LLM, chat-driven) scenarios. Without it the
# CLI still runs Tier-A (full learning pipeline via the scripted demo).
ANTHROPIC_API_KEY=

# Where the running harness server is. Default: http://localhost:4111
UAT_SERVER_URL=http://localhost:4111

# Optional: per-scenario poll timeout (ms). Real LLM + aux LLM extraction
# can take a while; default 120000.
UAT_TIMEOUT_MS=120000
